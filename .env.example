# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://travelsearch:CHANGE_ME@db:5432/travelsearch
POSTGRES_PASSWORD=CHANGE_ME

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_HEX

# ─── Scraping proxy pool ─────────────────────────────────────────────────────
PROXY_PROVIDER_HOST=proxy.example.com:8080
PROXY_PROVIDER_USER=proxyuser
PROXY_PROVIDER_PASS=CHANGE_ME

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=https://yourdomain.com

# ─── Scraping behaviour ──────────────────────────────────────────────────────
# Set to true only in local dev to persist raw scraped JSONB for debugging.
# Default false — raw snapshots may contain PII (reviewer names, location data).
ENABLE_RAW_SNAPSHOT=false

# ─── Default user ────────────────────────────────────────────────────────────
# Created (or password-synced) on every startup. Leave blank to skip.
DEFAULT_USER_EMAIL=admin@travelsearch.local
DEFAULT_USER_PASSWORD=CHANGE_ME

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "production" on VPS, "development" locally
APP_ENV=development
